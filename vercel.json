{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/src/routes/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/routes/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/src/routes/index.ts"
    }
  ]
}
